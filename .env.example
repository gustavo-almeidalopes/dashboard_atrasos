# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://usuario:senha@host:5432/ecolimp

# ── Sistema de monitoramento (mesmo URL para ambas as contas) ────────────────
SYSTEM_URL=https://seu-sistema.com/login

# ── Conta 1 ─────────────────────────────────────────────────────────────────
ACCOUNT_1_NAME=conta          # label usado como 'source' no banco
ACCOUNT_1_USER=conta@empresa.com
ACCOUNT_1_PASS=senha_conta_1

# ── Conta 2 ─────────────────────────────────────────────────────────────────
ACCOUNT_2_NAME=conta_dois
ACCOUNT_2_USER=login2@empresa.com
ACCOUNT_2_PASS=senha_conta_2

# ── Seletores CSS do scraper (inspecione o HTML do sistema e ajuste) ─────────
# Campo de usuário/login
SCRAPER_SEL_USER=input[name="login"]
# Campo de senha
SCRAPER_SEL_PASS=input[name="senha"]
# Botão de entrar
SCRAPER_SEL_SUBMIT=button[type="submit"]
# Botão de exportar Excel (deixe vazio para usar extração via HTML da tabela)
SCRAPER_SEL_EXPORT=
# URL da página do grid (se diferente da página de login)
SCRAPER_GRID_URL=

# ── Outras configurações ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000
TOP_RANKING=8
